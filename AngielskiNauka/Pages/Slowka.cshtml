@page
@model AngielskiNauka.Pages.SlowkaModel

@{
}

<style>
    .zaokraglony-div {
        padding: 15px 20px;
        border-radius: 20px;
        display: inline-flex; /* <-- kluczowa zmiana */
        align-items: center;
        gap: 10px;
        font-size: 1.1rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        cursor: pointer;
        margin-left: 10px; /* odstęp między divami */
    }

    body {
        background: #f0f4f8;
        font-family: 'Arial', sans-serif;
        height: 100vh;
        margin: 0;
    }

    .quiz-container {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        width: 400px;
        text-align: left;
    }

    .question {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 20px;
        color: #333;
    }

    .answers {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

        .answers button {
            background-color: #e3e9f0;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-size: 16px;
            cursor: pointer;
            transition: background-color 0.3s, transform 0.2s;
            text-align: left;
        }

            .answers button:hover {
                background-color: #c5d3e0;
                transform: scale(1.02);
            }

            .answers button:active {
                background-color: #a5b8cd;
                transform: scale(0.98);
            }

    .result {
        margin-top: 25px;
        font-size: 20px;
        font-weight: bold;
        color: #2b6cb0;
    }

    .fullscreen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: aliceblue;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        justify-content: left;
        align-items: center;
        color: black;
    }

    .summary {
        margin-bottom: 20px;
        padding: 10px;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

        .summary div {
            margin: 5px 0;
        }

    .words {
        background: #fff;
        padding: 10px;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .word {
        margin: 5px 0;
    }

        .word strong {
            color: #2c3e50;
        }
</style>

<h1>Fiszka ćwiczenie: @Model.PoziomName</h1>
<br />

<partial name="_Info" model="@Model.poziomid" />
<div id="quizContainer" class="quiz-container">
    <div class="question">
        <span id="ang"></span>
    </div>

    <div class="answers">
        <button onclick="answer(0)" id="pol0"></button>
        <button onclick="answer(1)" id="pol1"></button>
        <button onclick="answer(2)" id="pol2"></button>
        <button onclick="answer(3)" id="pol3"></button>
    </div>
   
</div>
 Stan:
<div id="nauka-bar-container" style="height: 25px; border-radius: 15px; background-color: #e0e0e0; overflow: hidden;">
    <div id="nauka-bar" style="height: 100%; width: 0%; border-radius: 15px;text-align:center">
        <span id="postepid">0</span>
    </div>
</div>
<script>
    var poziom = '@Model.poziomid';
     var dane=null;
     var teraz=0;
     var ok=0;
     LoadData();
     aktualizujKolorNauki(100)
     function answer(id) {
        teraz++;
        wait('Wysłamy odpowiedzi');
        if (dane.pol == dane.odpowiedzi[id]) {
           
             ok++;
            postjson("api/baza/update/" + dane.id + "/1", null, function (data) {
                $('#stan').text(data);
                LoadData();
                  aktualizujKolorNauki((ok / teraz) * 100);
            });
         
        }
        else {
               console.log(id,0);
            postjson("api/baza/update/" + dane.id + "/0", null, function (data) {
                $('#stan').text(data);
                LoadData();
                  aktualizujKolorNauki((ok / teraz) * 100);
            });
        }

    }
     function getKolorZPalety(procent) {
         let r, g;
         if (procent < 50) {
             r = 255;
             g = Math.round(5.1 * procent);
         } else {
             g = 255;
             r = Math.round(510 - 5.1 * procent);
         }
         return `rgb(${r},${g},0)`;
     }
      function aktualizujKolorNauki(procent) {
          
         if (!isNaN(procent)) {
             setValue('postepid', Math.floor(procent));
              setValue('postepid', ok+'/'+teraz);
         } else {
             setValue('postepid', '');
         }

         const bar = document.getElementById('nauka-bar');
         bar.style.width = procent + '%';
         bar.style.backgroundColor = getKolorZPalety(procent);
         bar.style.transition = 'width 0.5s ease, background-color 0.5s ease';
     }
      function LoadData() {
        getjson("api/baza/getslowa/" + poziom, function (data) 
        {
            dane=data;
            $('#ang').text(dane.ang);
            $('#mniej').text(dane.mniej);
            $('#rowna').text(dane.rowna);
            $('#wiecej').text(dane.wiecej);
            $('#pol0').text(dane.odpowiedzi[0]);
            $('#pol1').text(dane.odpowiedzi[1]);
            $('#pol2').text(dane.odpowiedzi[2]);
            $('#pol3').text(dane.odpowiedzi[3]);
            hideLoader();
           }, function (data) {
                console.log(data.message);
                hideLoader();
            });
        }
</script>
